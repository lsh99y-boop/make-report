def build_comparison_tab(ws, data=None, report_title=''):
    set_a4_print_setup(ws)
    thin=Side(style='thin'); medium=Side(style='medium')
    border=Border(top=thin,left=thin,right=thin,bottom=thin)
    hf=XlFont(name='Arial',bold=True,color="FFFFFF",size=11)
    hfill=PatternFill(start_color="203764",end_color="203764",fill_type="solid")
    ifill=PatternFill(start_color="D6E4F0",end_color="D6E4F0",fill_type="solid")
    ifill2=PatternFill(start_color="E2EFDA",end_color="E2EFDA",fill_type="solid")
    ifill3=PatternFill(start_color="FCE4D6",end_color="FCE4D6",fill_type="solid")
    ifill4=PatternFill(start_color="E4DFEC",end_color="E4DFEC",fill_type="solid")
    ifill5=PatternFill(start_color="FFF2CC",end_color="FFF2CC",fill_type="solid")
    ct=Alignment(horizontal='center',vertical='center',wrap_text=True)
    la=Alignment(horizontal='left',vertical='center',wrap_text=True,indent=1)
    bf=XlFont(name='Arial',bold=True,size=10)
    nf=XlFont(name='Arial',size=10)
    tf=XlFont(name='Arial',size=22,bold=True,color="203764")
    for c,w in [('A',4),('B',10),('C',13),('D',24),('E',24),('F',10),('G',10)]:
        ws.column_dimensions[c].width=w
    def cs(row,col,val,font=nf,fill=None,align=ct):
        c=ws.cell(row=row,column=col,value=val); c.font=font; c.alignment=align; c.border=border
        if fill: c.fill=fill
    def br(r1,r2,c1,c2):
        for r in range(r1,r2+1):
            for c in range(c1,c2+1): ws.cell(row=r,column=c).border=border
    def fr(r1,r2,c1,c2,fill):
        for r in range(r1,r2+1):
            for c in range(c1,c2+1): ws.cell(row=r,column=c).fill=fill
    def sv(idx):
        if data and 'singles' in data: return data['singles'].get(idx,'')
        return ''
    def pv(idx):
        if data and 'pairs' in data: return data['pairs'].get(idx,('',''))
        return '',''

    if report_title and report_title.strip():
        ws.merge_cells('B5:G7')
        rt=ws.cell(row=5,column=2,value=report_title.strip())
        rt.font=XlFont(name='Arial',size=32,bold=True,color="203764"); rt.alignment=ct
        for r in range(5,8):
            for c in range(2,8): ws.cell(row=r,column=c).border=border
        ws.row_dimensions[5].height=25; ws.row_dimensions[6].height=25; ws.row_dimensions[7].height=25
        ws.merge_cells('B12:G14')
        dc=ws.cell(row=12,column=2,value="대 조 검 사"); dc.font=tf; dc.alignment=ct
        for r in range(12,15):
            for c in range(2,8): ws.cell(row=r,column=c).border=border
        ws.row_dimensions[12].height=22; ws.row_dimensions[13].height=22; ws.row_dimensions[14].height=22
        ws.row_dimensions[15].height=6; d=11
    else:
        ws.merge_cells('B5:G7')
        dc=ws.cell(row=5,column=2,value="대 조 검 사"); dc.font=tf; dc.alignment=ct
        for r in range(5,8):
            for c in range(2,8): ws.cell(row=r,column=c).border=border
        ws.row_dimensions[5].height=22; ws.row_dimensions[6].height=22
        ws.row_dimensions[7].height=22; ws.row_dimensions[8].height=6; d=4
    R=lambda n: n+d

    ws.merge_cells(f'B{R(5)}:C{R(5)}'); ws.merge_cells(f'D{R(5)}:E{R(5)}')
    for col in range(2,8):
        c=ws.cell(row=R(5),column=col); c.font=hf; c.fill=hfill; c.alignment=ct; c.border=border
    cs(R(5),2,"검사항목",hf,hfill); cs(R(5),4,"대조사항",hf,hfill)
    cs(R(5),6,"검사결과",hf,hfill); cs(R(5),7,"비고",hf,hfill)

    for row,item,ri in [(R(6),"시설자",0),(R(7),"허가번호",1),(R(8),"무선국명",2)]:
        ws.merge_cells(f'B{row}:C{row}'); ws.merge_cells(f'D{row}:E{row}')
        cs(row,2,item,bf,ifill); cs(row,4,sv(ri),nf); br(row,row,2,7); fr(row,row,2,3,ifill)

    ws.merge_cells(f'B{R(9)}:B{R(10)}'); cs(R(9),2,"설치장소",bf,ifill2); fr(R(9),R(10),2,2,ifill2)
    ws.merge_cells(f'D{R(9)}:E{R(9)}'); cs(R(9),3,"연주소",bf)
    cs(R(9),4,sv(3),nf,align=la); br(R(9),R(9),2,7)
    ws.merge_cells(f'D{R(10)}:E{R(10)}'); cs(R(10),3,"송신소",bf)
    cs(R(10),4,sv(4),nf,align=la); br(R(10),R(10),2,7)

    ws.merge_cells(f'B{R(11)}:B{R(22)}')
    cs(R(11),2,"송신기",XlFont(name='Arial',bold=True,size=11),ifill3)
    fr(R(11),R(22),2,2,ifill3); br(R(11),R(22),2,7)
    for row,sub,ri in [(R(11),"장치구분",5),(R(12),"제조자명",6),(R(13),"형식 명칭",7),
        (R(14),"일련번호",8),(R(15),"발진방식",9),(R(16),"변조방식",10),
        (R(17),"체배방식",11),(R(18),"종단 명칭",12),(R(19),"종단 개수",13)]:
        v1,v2=pv(ri); cs(row,3,sub,bf); cs(row,4,v1,nf); cs(row,5,v2,nf)
    for row,sub,ri in [(R(20),"전력저하장치",14),(R(21),"안전시설",15),(R(22),"보호장치",16)]:
        ws.merge_cells(f'D{row}:E{row}'); cs(row,3,sub,bf); cs(row,4,sv(ri),nf)

    ws.merge_cells(f'B{R(23)}:B{R(25)}')
    cs(R(23),2,"공중선",XlFont(name='Arial',bold=True,size=11),ifill4)
    fr(R(23),R(25),2,2,ifill4); br(R(23),R(25),2,7)
    for row,sub,ri in [(R(23),"형식",17),(R(24),"구성",18),(R(25),"지향성",19)]:
        ws.merge_cells(f'D{row}:E{row}'); cs(row,3,sub,bf); cs(row,4,sv(ri),nf)

    ws.merge_cells(f'B{R(26)}:B{R(27)}')
    cs(R(26),2,"접지방식",XlFont(name='Arial',bold=True,size=11),ifill5)
    fr(R(26),R(27),2,2,ifill5); br(R(26),R(27),2,7)
    for row,sub,ri in [(R(26),"기기",20),(R(27),"공중선",21)]:
        ws.merge_cells(f'D{row}:E{row}'); cs(row,3,sub,bf); cs(row,4,sv(ri),nf)

    ws.merge_cells(f'B{R(28)}:C{R(28)}'); ws.merge_cells(f'D{R(28)}:E{R(28)}')
    cs(R(28),2,"전원설비",bf,ifill); cs(R(28),4,sv(22),nf)
    br(R(28),R(28),2,7); fr(R(28),R(28),2,3,ifill)

    ws.row_dimensions[R(5)].height=22
    for r in range(R(6),R(29)): ws.row_dimensions[r].height=20
    for r in range(R(5),R(29)):
        c=ws.cell(row=r,column=2); c.border=Border(top=c.border.top,left=medium,right=c.border.right,bottom=c.border.bottom)
        c=ws.cell(row=r,column=7); c.border=Border(top=c.border.top,left=c.border.left,right=medium,bottom=c.border.bottom)
    for col in range(2,8):
        c=ws.cell(row=R(5),column=col); c.border=Border(top=medium,left=c.border.left,right=c.border.right,bottom=c.border.bottom)
        c=ws.cell(row=R(28),column=col); c.border=Border(top=c.border.top,left=c.border.left,right=c.border.right,bottom=medium)
    ws.cell(row=R(5),column=2).border=Border(top=medium,left=medium,right=thin,bottom=thin)
    ws.cell(row=R(5),column=7).border=Border(top=medium,left=thin,right=medium,bottom=thin)
    ws.cell(row=R(28),column=2).border=Border(top=thin,left=medium,right=thin,bottom=medium)
    ws.cell(row=R(28),column=7).border=Border(top=thin,left=thin,right=medium,bottom=medium)
    ws.print_area=f'A1:H{R(30)}'

# ==========================================
# [5] 보고서 생성
# ==========================================
def generate_report(config, output_path, report_title='', log_func=print):
    txa_excel=config.get('txa_excel','')
    txb_excel=config.get('txb_excel','')
    comp_xlsx=config.get('comp_xlsx','')

    txa_name=os.path.splitext(os.path.basename(txa_excel))[0][:31] if txa_excel else "TXA"
    txb_name=os.path.splitext(os.path.basename(txb_excel))[0][:31] if txb_excel else "TXB"

    wb=Workbook()

    # TXA
    if txa_excel and os.path.exists(txa_excel):
        log_func(f"[{txa_name}] 원본 복사 + 수검 표 삽입 중...")
        try:
            src_wb=load_workbook(txa_excel)
            ws_a=wb.create_sheet(title=txa_name)
            copy_full_sheet(src_wb.active, ws_a)
            insert_blank_rows_pages234(ws_a)
            insert_inspection_page(ws_a, 'TX-A',
                {'power':config.get('txa_power',''),'bw':config.get('txa_bw_val',''),'freq':config.get('txa_freq_val','')},
                {'bw':config.get('txa_bw_img',''),'freq':config.get('txa_freq_img','')}, log_func)
            log_func(f"  ✅ [{txa_name}] 완료")
        except Exception as e:
            log_func(f"  ⚠️ 실패: {e}"); traceback.print_exc()

    # TXB
    if txb_excel and os.path.exists(txb_excel):
        log_func(f"[{txb_name}] 원본 복사 + 수검 표 삽입 중...")
        try:
            src_wb=load_workbook(txb_excel)
            ws_b=wb.create_sheet(title=txb_name)
            copy_full_sheet(src_wb.active, ws_b)
            insert_blank_rows_pages234(ws_b)
            insert_inspection_page(ws_b, 'TX-B',
                {'power':config.get('txb_power',''),'bw':config.get('txb_bw_val',''),'freq':config.get('txb_freq_val','')},
                {'bw':config.get('txb_bw_img',''),'freq':config.get('txb_freq_img','')}, log_func)
            log_func(f"  ✅ [{txb_name}] 완료")
        except Exception as e:
            log_func(f"  ⚠️ 실패: {e}"); traceback.print_exc()

    # 대조검사
    log_func("대조검사 탭 생성 중...")
    ws_comp=wb.create_sheet(title='대조검사')
    comp_data=None
    if comp_xlsx and os.path.exists(comp_xlsx):
        log_func(f"  대조검사 엑셀 읽기: {os.path.basename(comp_xlsx)}")
        comp_data=read_comparison_excel(comp_xlsx, log_func)
    else:
        log_func("  대조검사 엑셀 없음 → 빈 표 생성")
    build_comparison_tab(ws_comp, comp_data, report_title)
    log_func("  ✅ 대조검사 표 완료")

    wb.move_sheet('대조검사',offset=-(len(wb.sheetnames)-1))
    if 'Sheet' in wb.sheetnames: del wb['Sheet']
    wb.save(output_path); log_func(f"\n✅ 저장 완료: {output_path}"); return output_path

