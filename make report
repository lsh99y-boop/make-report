# [6] Windows GUI
# ==========================================
class App:
    def __init__(self,root):
        self.root=root; self.root.title("DTV 무선국 수검자료 생성기")
        self.root.geometry("700x820"); self.root.resizable(True,True)
        self.vars={
            'txa_excel':StringVar(),'txa_power':StringVar(),'txa_bw_val':StringVar(),
            'txa_freq_val':StringVar(),'txa_bw_img':StringVar(),'txa_freq_img':StringVar(),
            'txb_excel':StringVar(),'txb_power':StringVar(),'txb_bw_val':StringVar(),
            'txb_freq_val':StringVar(),'txb_bw_img':StringVar(),'txb_freq_img':StringVar(),
            'comp_xlsx':StringVar(),'report_title':StringVar(),
            'output_name':StringVar(value="무선국_수검자료_최종통합본.xlsx"),
        }
        self.build_gui()

    def build_gui(self):
        main=Frame(self.root,padx=15,pady=10); main.pack(fill=BOTH,expand=True)
        Label(main,text="DTV 무선국 수검자료 생성기",font=("맑은 고딕",18,"bold"),fg="#203764").pack(pady=(0,2))
        Label(main,text="원본 엑셀 + 수검 측정결과/이미지 + 대조검사",font=("맑은 고딕",9),fg="#888").pack()
        ttk.Separator(main,orient='horizontal').pack(fill=X,pady=8)

        # TX-A
        self.add_section(main,"TX-A",[
            ("원본 엑셀 (.xlsx)",'txa_excel','엑셀'),
            ("점유주파수대역폭 이미지",'txa_bw_img','이미지'),
            ("주파수정확도 이미지",'txa_freq_img','이미지'),
        ])
        tf=Frame(main); tf.pack(fill=X,padx=(30,0),pady=2)
        Label(tf,text="공중선전력:",font=("맑은 고딕",8)).grid(row=0,column=0,sticky=W)
        Entry(tf,textvariable=self.vars['txa_power'],font=("맑은 고딕",8),width=15).grid(row=0,column=1,padx=3)
        Label(tf,text="점유주파수:",font=("맑은 고딕",8)).grid(row=0,column=2,sticky=W)
        Entry(tf,textvariable=self.vars['txa_bw_val'],font=("맑은 고딕",8),width=15).grid(row=0,column=3,padx=3)
        Label(tf,text="주파수정확도:",font=("맑은 고딕",8)).grid(row=0,column=4,sticky=W)
        Entry(tf,textvariable=self.vars['txa_freq_val'],font=("맑은 고딕",8),width=15).grid(row=0,column=5,padx=3)

        # TX-B
        self.add_section(main,"TX-B",[
            ("원본 엑셀 (.xlsx)",'txb_excel','엑셀'),
            ("점유주파수대역폭 이미지",'txb_bw_img','이미지'),
            ("주파수정확도 이미지",'txb_freq_img','이미지'),
        ])
        tf2=Frame(main); tf2.pack(fill=X,padx=(30,0),pady=2)
        Label(tf2,text="공중선전력:",font=("맑은 고딕",8)).grid(row=0,column=0,sticky=W)
        Entry(tf2,textvariable=self.vars['txb_power'],font=("맑은 고딕",8),width=15).grid(row=0,column=1,padx=3)
        Label(tf2,text="점유주파수:",font=("맑은 고딕",8)).grid(row=0,column=2,sticky=W)
        Entry(tf2,textvariable=self.vars['txb_bw_val'],font=("맑은 고딕",8),width=15).grid(row=0,column=3,padx=3)
        Label(tf2,text="주파수정확도:",font=("맑은 고딕",8)).grid(row=0,column=4,sticky=W)
        Entry(tf2,textvariable=self.vars['txb_freq_val'],font=("맑은 고딕",8),width=15).grid(row=0,column=5,padx=3)

        # 대조검사
        self.add_section(main,"대조검사",[("대조검사 엑셀 (.xlsx)",'comp_xlsx','엑셀')])

        ttk.Separator(main,orient='horizontal').pack(fill=X,pady=6)
        sf=Frame(main); sf.pack(fill=X,pady=2)
        Label(sf,text="보고서 제목:",font=("맑은 고딕",9)).grid(row=0,column=0,sticky=W,pady=2)
        Entry(sf,textvariable=self.vars['report_title'],font=("맑은 고딕",10),width=55).grid(row=0,column=1,sticky=W,padx=5,pady=2)
        Label(sf,text="출력 파일명:",font=("맑은 고딕",9)).grid(row=1,column=0,sticky=W,pady=2)
        Entry(sf,textvariable=self.vars['output_name'],font=("맑은 고딕",10),width=55).grid(row=1,column=1,sticky=W,padx=5,pady=2)

        self.gen_btn=Button(main,text="보고서 생성",font=("맑은 고딕",13,"bold"),bg="#28a745",fg="white",height=2,command=self.on_generate)
        self.gen_btn.pack(fill=X,pady=8)
        lf=Frame(main); lf.pack(fill=BOTH,expand=True)
        self.log_text=Text(lf,height=8,font=("Consolas",9),wrap=WORD,state='disabled')
        sb=Scrollbar(lf,command=self.log_text.yview); self.log_text.configure(yscrollcommand=sb.set)
        sb.pack(side=RIGHT,fill=Y); self.log_text.pack(fill=BOTH,expand=True)

    def add_section(self,parent,title,fields):
        Label(parent,text=title,font=("맑은 고딕",11,"bold"),fg="#203764").pack(anchor=W,pady=(8,2))
        for label,vk,ft in fields:
            row=Frame(parent); row.pack(fill=X,pady=1,padx=(15,0))
            Label(row,text=label+":",font=("맑은 고딕",9),width=22,anchor=W).pack(side=LEFT)
            Entry(row,textvariable=self.vars[vk],font=("맑은 고딕",8),width=38).pack(side=LEFT,padx=3)
            Button(row,text="찾아보기",font=("맑은 고딕",8),command=lambda k=vk,t=ft:self.browse_file(k,t)).pack(side=LEFT)

    def browse_file(self,vk,ft):
        t=[("Excel","*.xlsx"),("All","*.*")] if ft=='엑셀' else [("Image","*.png *.jpg *.jpeg *.bmp"),("All","*.*")]
        p=filedialog.askopenfilename(filetypes=t)
        if p: self.vars[vk].set(p)

    def log(self,msg):
        self.log_text.configure(state='normal'); self.log_text.insert(END,msg+"\n")
        self.log_text.see(END); self.log_text.configure(state='disabled'); self.root.update_idletasks()

    def on_generate(self):
        self.log_text.configure(state='normal'); self.log_text.delete('1.0',END); self.log_text.configure(state='disabled')
        config={k:self.vars[k].get() for k in self.vars if k not in ('report_title','output_name')}
        if not(config['txa_excel'] or config['txb_excel']):
            messagebox.showwarning("알림","TXA 또는 TXB 원본 엑셀 파일을 최소 1개 선택해 주세요!"); return
        op=filedialog.asksaveasfilename(defaultextension=".xlsx",initialfile=self.vars['output_name'].get(),
            filetypes=[("Excel","*.xlsx")],title="보고서 저장 위치 선택")
        if not op: return
        rt=self.vars['report_title'].get().strip()
        self.gen_btn.configure(state='disabled',text="⏳ 생성 중...")
        self.log("="*45); self.log("  보고서 생성 시작"); self.log("="*45)
        def run():
            try:
                generate_report(config,op,rt,log_func=self.log)
                self.root.after(0,lambda:messagebox.showinfo("완료",f"보고서가 생성되었습니다!\n\n{op}"))
                self.root.after(0,lambda:os.startfile(os.path.dirname(op)))
            except PermissionError:
                self.log(f"\n❌ 엑셀에서 파일이 열려 있습니다! 닫고 다시 시도하세요.")
                self.root.after(0,lambda:messagebox.showerror("파일 사용 중",
                    "엑셀에서 파일이 열려 있어 저장할 수 없습니다.\n엑셀에서 파일을 닫은 후 다시 시도해 주세요."))
            except Exception as e:
                self.log(f"\n❌ 오류: {e}"); traceback.print_exc()
                self.root.after(0,lambda:messagebox.showerror("오류",f"보고서 생성 실패:\n{e}"))
            finally:
                self.root.after(0,lambda:self.gen_btn.configure(state='normal',text="보고서 생성"))
        threading.Thread(target=run,daemon=True).start()

if __name__=="__main__":
    root=Tk(); app=App(root); root.mainloop()
