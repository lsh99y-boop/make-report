def set_a4_print_setup(ws):
    ws.page_setup.orientation=ws.ORIENTATION_PORTRAIT; ws.page_setup.paperSize=ws.PAPERSIZE_A4
    ws.page_setup.fitToWidth=1; ws.page_setup.fitToHeight=0
    ws.sheet_properties.pageSetUpPr.fitToPage=True
    ws.page_margins=PageMargins(left=0.5,right=0.3,top=0.5,bottom=0.5,header=0.3,footer=0.3)
    ws.print_options.horizontalCentered=True

def copy_full_sheet(src, dst):
    # 기본 행 높이/열 너비 복사 (원본과 동일하게)
    if src.sheet_format.defaultRowHeight:
        dst.sheet_format.defaultRowHeight = src.sheet_format.defaultRowHeight
    if src.sheet_format.defaultColWidth:
        dst.sheet_format.defaultColWidth = src.sheet_format.defaultColWidth
    for col_letter, dim in src.column_dimensions.items():
        dst.column_dimensions[col_letter].width=dim.width
        dst.column_dimensions[col_letter].hidden=dim.hidden
    for row_num, dim in src.row_dimensions.items():
        dst.row_dimensions[row_num].height=dim.height
        dst.row_dimensions[row_num].hidden=dim.hidden
    for row in src.iter_rows():
        for cell in row:
            nc=dst.cell(row=cell.row,column=cell.column,value=cell.value)
            if cell.has_style:
                nc.font=copy(cell.font); nc.border=copy(cell.border)
                nc.fill=copy(cell.fill); nc.alignment=copy(cell.alignment)
                nc.number_format=cell.number_format
    for m in src.merged_cells.ranges:
        try: dst.merge_cells(str(m))
        except: pass
    if hasattr(src,'_images'):
        for img in src._images: dst.add_image(deepcopy(img))
    dst.page_setup.orientation=src.page_setup.orientation
    dst.page_setup.paperSize=src.page_setup.paperSize
    if src.page_setup.fitToWidth: dst.page_setup.fitToWidth=src.page_setup.fitToWidth
    if src.page_setup.fitToHeight: dst.page_setup.fitToHeight=src.page_setup.fitToHeight
    if src.sheet_properties.pageSetUpPr and src.sheet_properties.pageSetUpPr.fitToPage:
        dst.sheet_properties.pageSetUpPr.fitToPage=True
    if src.print_area: dst.print_area=src.print_area
    dst.page_margins=PageMargins(
        left=src.page_margins.left,right=src.page_margins.right,
        top=src.page_margins.top,bottom=src.page_margins.bottom,
        header=src.page_margins.header,footer=src.page_margins.footer)
    for brk in src.row_breaks.brk: dst.row_breaks.append(brk)
    for brk in src.col_breaks.brk: dst.col_breaks.append(brk)

def insert_blank_rows_pages234(ws):
    """2,3,4페이지 섹션 제목 위 행의 높이를 키워서 간격 확보 (원본 데이터 훼손 없음)
    + 섹션 제목 B~H 병합 가운데 정렬"""
    page_titles = ['Frequency Response & Group Delay',
                   'Amplitude & Phase Error',
                   'Out of Channel Spectrum']
    for r in range(1, ws.max_row + 1):
        v = ws.cell(row=r, column=2).value
        if v and isinstance(v, str) and v.strip() in page_titles:
            # 제목 위 행의 높이를 키움 (빈 행 1개 추가 효과)
            if r > 1:
                prev_h = ws.row_dimensions[r-1].height or ws.sheet_format.defaultRowHeight or 16.5
                ws.row_dimensions[r-1].height = prev_h + 17  # 약 1행 높이 추가

    # 섹션 제목 B~H 병합 + 가운데 정렬
    section_titles = ['Frequency Response & Group Delay', 'Amplitude & Phase Error',
        'Out of Channel Spectrum', 'Peak/Average & Channel Spectrum',
        'Signal/Noise & EVM', 'Phase Noise', 'Harmonic', 'Summary']
    for r in range(1, ws.max_row + 1):
        v = ws.cell(row=r, column=2).value
        if v and isinstance(v, str) and v.strip() in section_titles:
            # 기존 B~G 병합 해제 후 B~H로 확장
            for m in list(ws.merged_cells.ranges):
                if m.min_row == r and m.min_col == 2 and m.max_col >= 6:
                    ws.unmerge_cells(str(m)); break
            try: ws.merge_cells(start_row=r, start_column=2, end_row=r, end_column=8)
            except: pass
            ws.cell(row=r, column=2).alignment = Alignment(horizontal='center', vertical='center')

# ==========================================
# [2] TXA/TXB 첫 페이지에 수검 표+이미지 삽입
# ==========================================
def insert_inspection_page(ws, tx_label, measurements, images, log_func=print):
    """원본 복사된 시트의 첫 페이지에 수검 표+이미지 삽입
    tx_label: 'TX-A' 또는 'TX-B'
    measurements: {'power':'', 'bw':'', 'freq':''}  측정결과 값
    images: {'bw':'경로', 'freq':'경로'}  이미지 파일 경로
    """
    # REPORT 병합 해제 및 삭제
    for m in list(ws.merged_cells.ranges):
        if m.min_row<=6 and m.min_col==2 and m.max_col>=6:
            ws.unmerge_cells(str(m))
    for r in range(1,7):
        for c in range(1,9): ws.cell(row=r,column=c,value=None)

    thin=Side(style='thin')
    border=Border(top=thin,left=thin,right=thin,bottom=thin)
    hf=XlFont(name='Arial',bold=True,color="FFFFFF",size=11)
    hfill=PatternFill(start_color="203764",end_color="203764",fill_type="solid")
    ct=Alignment(horizontal='center',vertical='center',wrap_text=True)
    bf=XlFont(name='Arial',bold=True,size=10)
    nf=XlFont(name='Arial',size=10)

    # Row 2~3: TX 제목
    ws.merge_cells('B2:G3')
    c=ws.cell(row=2,column=2,value=tx_label)
    c.font=XlFont(name='Arial',size=28,bold=True); c.alignment=ct

    def make_table(r, title, device, limit, result_val):
        ws.merge_cells(f'B{r}:G{r}')
        tc=ws.cell(row=r,column=2,value=title)
        tc.font=bf; tc.alignment=ct
        r+=1
        for i,h in enumerate(["장치","검사기준","측정결과","","적부","비고"]):
            c=ws.cell(row=r,column=2+i,value=h)
            c.font=hf; c.fill=hfill; c.alignment=ct; c.border=border
        ws.merge_cells(f'D{r}:E{r}')
        r+=1
        for i,v in enumerate([device, limit, result_val,"","적합",""]):
            c=ws.cell(row=r,column=2+i,value=v)
            c.font=nf; c.alignment=ct; c.border=border
        ws.merge_cells(f'D{r}:E{r}')
        r+=1
        return r

    def insert_img(r, img_path, num_rows=12):
        """이미지를 B열~G열에 꽉 차게, 지정 행 수만큼 삽입 (TwoCellAnchor)"""
        if img_path and os.path.exists(img_path):
            try:
                from openpyxl.utils.units import pixels_to_EMU, cm_to_EMU
                from openpyxl.drawing.spreadsheet_drawing import AnchorMarker, TwoCellAnchor
                img=OpenpyxlImage(img_path)
                # TwoCellAnchor: B열(0-based=1) ~ G열 끝(0-based=7), num_rows행
                marker_from=AnchorMarker(col=1,colOff=0,row=r-1,rowOff=0)
                marker_to=AnchorMarker(col=7,colOff=0,row=r-1+num_rows,rowOff=0)
                img.anchor=TwoCellAnchor(_from=marker_from,to=marker_to)
                ws.add_image(img)
                log_func(f"    이미지 삽입: Row {r} (B~G, {num_rows}행)")
                return True
            except Exception as e:
                log_func(f"    ⚠️ 이미지 삽입 실패: {e}")
        return False

    def draw_section_border(start_row, end_row):
        """B~G열, start_row~end_row 섹션 전체 외곽+좌우 테두리"""
        thin_side=Side(style='thin')
        for row in range(start_row, end_row+1):
            for col in range(2, 8):  # B=2 ~ G=7
                cell=ws.cell(row=row,column=col)
                existing=cell.border
                # 기존 테두리 유지하면서 외곽만 추가
                t=existing.top if (existing.top and existing.top.style) else (thin_side if row==start_row else None)
                b=existing.bottom if (existing.bottom and existing.bottom.style) else (thin_side if row==end_row else None)
                l=thin_side if col==2 else (existing.left if (existing.left and existing.left.style) else None)
                r_side=thin_side if col==7 else (existing.right if (existing.right and existing.right.style) else None)
                cell.border=Border(top=t,bottom=b,left=l,right=r_side)

    r=5
    # 1. 공중선 전력
    r=make_table(r,"1. 공중선 전력",tx_label,"상한 5%, 하한 5%",measurements.get('power',''))
    r+=1

    # 2. 점유주파수대역폭
    bw_section_start=r
    r=make_table(r,"2. 점유주파수대역폭",tx_label,"6MHz 이하",measurements.get('bw',''))
    insert_img(r, images.get('bw',''), num_rows=12)
    bw_section_end=r+12-1
    draw_section_border(bw_section_start, bw_section_end)
    r+=12

    r+=1  # 점유주파수대역폭↔주파수정확도 사이 간격 1행

    # 3. 주파수 허용 편차
    freq_section_start=r
    r=make_table(r,"3. 주파수 허용 편차 (주파수 정확도)",tx_label,"±1ppm 이하",measurements.get('freq',''))
    insert_img(r, images.get('freq',''), num_rows=12)
    freq_section_end=r+12-1
    draw_section_border(freq_section_start, freq_section_end)
    r+=12

    # 주파수정확도 이미지 아래 빈 행 1행 삭제
    ws.delete_rows(r, 1)

    log_func(f"  수검 표 삽입 완료 (표3개 + 이미지 B~G 12행 + 섹션 테두리)")

# ==========================================
# [3] 대조검사 엑셀에서 데이터 읽기
# ==========================================
def read_comparison_excel(xlsx_path, log_func=print):
    try:
        wb=load_workbook(xlsx_path,data_only=True); ws=wb.active
    except Exception as e:
        log_func(f"  ⚠️ 엑셀 열기 실패: {e}"); return None
    def cv(row,col):
        v=ws.cell(row=row,column=col).value
        return str(v).strip() if v is not None else ''
    singles={0:cv(2,4),1:cv(3,4),2:cv(4,4),3:cv(5,4),4:cv(6,4),
        14:cv(16,4),15:cv(17,4),16:cv(18,4),17:cv(19,4),
        18:cv(20,4),19:cv(21,4),20:cv(22,4),21:cv(23,4),22:cv(24,4)}
    pairs={5:(cv(7,4),cv(7,5)),6:(cv(8,4),cv(8,5)),7:(cv(9,4),cv(9,5)),
        8:(cv(10,4),cv(10,5)),9:(cv(11,4),cv(11,5)),10:(cv(12,4),cv(12,5)),
        11:(cv(13,4),cv(13,5)),12:(cv(14,4),cv(14,5)),13:(cv(15,4),cv(15,5))}
    has_data=any(v for v in singles.values()) or any(v1 or v2 for v1,v2 in pairs.values())
    if not has_data:
        log_func("  ⚠️ 엑셀에 데이터가 없습니다"); return None
    filled=sum(1 for v in singles.values() if v)+sum(1 for v1,v2 in pairs.values() if v1 or v2)
    log_func(f"  ✅ 엑셀 읽기 완료: {filled}개 항목")
    log_func(f"    시설자: {singles[0]}")
    log_func(f"    허가번호: {singles[1]}")
    log_func(f"    무선국명: {singles[2]}")
    return {'singles':singles,'pairs':pairs}

